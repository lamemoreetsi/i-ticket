<Context>
    <Resource name="jdbc/ITICKET"
              auth="Container"
              type="javax.sql.DataSource"
              maxTotal="20"
              maxIdle="5"
              maxWaitMillis="10000"
              username="your_db_username"
              password="your_db_password"
              driverClassName="com.mysql.cj.jdbc.Driver"
              url="jdbc:mysql://localhost:3306/ITICKET?useSSL=false&amp;serverTimezone=UTC"/>

</Context>
